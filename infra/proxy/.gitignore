# Build output
dist/

# Test build artifacts
.dist/

# Compiled JavaScript files (keep nginx.js which is not ours, and test files)
config/**/*.js
!config/main/nginx.js
!config/**/tests/*.js
!config/**/main-reference/*.js

# Deployment secrets and backups
deploy/secrets.env
deploy/backups/

# Environment config files (contain secrets)
config/main/.env
config/global-components.vnext/.env

# Local mkcert output for the proxy dev stack — generated on demand by
# whichever branch wires up the dockerised proxy. Lingering on disk after
# branch switches; safe to ignore globally.
docker/certs/
