                  "value": {
                    "resourceIds": [
                      "/subscriptions/__SUBSCRIPTION_ID__/resourcegroups/rg-global-nav-dev/providers/microsoft.operationalinsights/workspaces/la-global-nav-dev"
                    ]
                  }
                },
                {
                  "isOptional": true,
                  "name": "PartId",
                  "value": "45b638ca-515d-4276-ad12-46fe12d15f11"
                },
                {
                  "isOptional": true,
                  "name": "Version",
                  "value": "2.0"
                },
                {
                  "isOptional": true,
                  "name": "TimeRange"
                },
                {
                  "isOptional": true,
                  "name": "DashboardId"
                },
                {
                  "isOptional": true,
                  "name": "DraftRequestParameters"
                },
                {
                  "isOptional": true,
                  "name": "Query",
                  "value": "let PerCase = GloCo_PageViews_CaseReview\n| where TimeGenerated > datetime(2026-03-09T12:00:01)\n| summarize\n    Has_Review_First_Review         = countif(Is_Review_First_Review) > 0,\n    Has_Review_Subsequent_Review    = countif(Is_Review_Subsequent_Review) > 0,\n    Has_Early_Advice_First_Review   = countif(Is_Early_Advice_First_Review) > 0,\n    Has_Early_Advice_Subsequent     = countif(Is_Early_Advice_Subsequent) > 0,\n    Has_Submitted_First_Review      = countif(Is_Submitted_First_Review) > 0,\n    Has_Submitted_Subsequent_Review = countif(Is_Submitted_Subsequent_Review) > 0,\n    Has_Admin_Finalise              = countif(Is_Admin_Finalise) > 0,\n    Submitted_By                    = take_anyif(Auth_Username, (Is_Submitted_First_Review or Is_Submitted_Subsequent_Review or Is_Admin_Finalise) and isnotempty(Auth_Username))\n    by CaseId;\nlet Min_Date            = toscalar(GloCo_PageViews_CaseReview | where TimeGenerated > datetime(2026-03-09T12:00:01) | summarize min(TimeGenerated));\nlet First_Review_Users  = toscalar(PerCase | where Has_Submitted_First_Review      and isnotempty(Submitted_By) | distinct Submitted_By | count);\nlet Subsequent_Users    = toscalar(PerCase | where Has_Submitted_Subsequent_Review and isnotempty(Submitted_By) | distinct Submitted_By | count);\nlet EA_First_Users      = toscalar(PerCase | where Has_Early_Advice_First_Review   and isnotempty(Submitted_By) | distinct Submitted_By | count);\nlet EA_Subsequent_Users = toscalar(PerCase | where Has_Early_Advice_Subsequent     and isnotempty(Submitted_By) | distinct Submitted_By | count);\nlet Admin_Users         = toscalar(PerCase | where Has_Admin_Finalise              and isnotempty(Submitted_By) | distinct Submitted_By | count);\nlet Total_Users         = toscalar(PerCase | where isnotempty(Submitted_By) | distinct Submitted_By | count);\nlet Stats = PerCase\n| summarize\n    First_Review_Started    = countif(Has_Review_First_Review),\n    First_Review_Submitted  = countif(Has_Review_First_Review      and Has_Submitted_First_Review),\n    Subsequent_Started      = countif(Has_Review_Subsequent_Review),\n    Subsequent_Submitted    = countif(Has_Review_Subsequent_Review  and Has_Submitted_Subsequent_Review),\n    EA_First_Started        = countif(Has_Early_Advice_First_Review),\n    EA_First_Submitted      = countif(Has_Early_Advice_First_Review and Has_Submitted_First_Review),\n    EA_Subsequent_Started   = countif(Has_Early_Advice_Subsequent),\n    EA_Subsequent_Submitted = countif(Has_Early_Advice_Subsequent   and Has_Submitted_Subsequent_Review),\n    Admin_Finalised         = countif(Has_Admin_Finalise);\nlet Rows = Stats\n| project\n    Review_Type = pack_array(\"First review\", \"Subsequent review\", \"EA first review\", \"EA subsequent review\", \"Admin finalised\"),\n    Started     = pack_array(First_Review_Started,   Subsequent_Started,   EA_First_Started,   EA_Subsequent_Started,   Admin_Finalised),\n    Submitted   = pack_array(First_Review_Submitted, Subsequent_Submitted, EA_First_Submitted, EA_Subsequent_Submitted, Admin_Finalised),\n    Users       = pack_array(First_Review_Users,     Subsequent_Users,     EA_First_Users,     EA_Subsequent_Users,     Admin_Users)\n| mv-expand Review_Type to typeof(string), Started to typeof(long), Submitted to typeof(long), Users to typeof(long);\nlet TotalRow = Stats\n| project\n    Review_Type = \"Total\",\n    Started     = First_Review_Started + Subsequent_Started + EA_First_Started + EA_Subsequent_Started + Admin_Finalised,\n    Submitted   = First_Review_Submitted + Subsequent_Submitted + EA_First_Submitted + EA_Subsequent_Submitted + Admin_Finalised,\n    Users       = Total_Users;\nlet DateRow = print\n    Review_Type = \"Earliest date\",\n    Started     = tostring(format_datetime(Min_Date, 'yyyy-MM-dd HH:mm')),\n    Submitted   = \"\",\n    Users       = \"\",\n    SortKey     = 7;\nunion\n    (Rows     | extend SortKey = case(Review_Type == \"First review\", 1, Review_Type == \"Subsequent review\", 2, Review_Type == \"EA first review\", 3, Review_Type == \"EA subsequent review\", 4, Review_Type == \"Admin finalised\", 5, 7) | project Review_Type, Started = tostring(Started), Submitted = tostring(Submitted), Users = tostring(Users), SortKey),\n    (TotalRow | extend SortKey = 6 | project Review_Type, Started = tostring(Started), Submitted = tostring(Submitted), Users = tostring(Users), SortKey),\n    DateRow\n| order by SortKey asc\n| project-away SortKey\n"
                },
                {
                  "isOptional": true,
                  "name": "ControlType",
                  "value": "AnalyticsGrid"
                },
                {
                  "isOptional": true,
                  "name": "SpecificChart"
                },
                {
                  "isOptional": true,
                  "name": "PartTitle",
                  "value": "Analytics"
                },
